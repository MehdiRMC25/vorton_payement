# Server
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Allowed origins (comma-separated) — for website and mobile app
# Example: https://yourapp.com,https://www.yourapp.com,capacitor://localhost
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Auth — API key or JWT secret for mobile app / website
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=
JWT_SECRET=

# Auth.js (sign-in) — optional; if set, /auth and /api/v1/auth/session are enabled
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=
# GitHub OAuth (optional; if set with AUTH_SECRET, sign in with GitHub is available)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Kapital Bank E-commerce API
# Test: https://txpgtst.kapitalbank.az/api
# Prod: https://e-commerce.kapitalbank.az/api
KAPITAL_BASE_URL=https://txpgtst.kapitalbank.az/api
KAPITAL_USERNAME=TerminalSys/kapital
KAPITAL_PASSWORD=kapital123
# Where Kapital redirects the user after payment (your frontend/app URL that receives ID & STATUS)
CALLBACK_URL=https://yourdomain.com/api/payment/callback

# Your business (for receipts / statements)
BUSINESS_NAME=Your Business Name
SUPPORT_EMAIL=support@example.com
